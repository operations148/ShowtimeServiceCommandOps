# ServiceOps Command Center — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# App
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_APP_URL=

# GoHighLevel Integration
GHL_API_BASE_URL=https://services.leadconnectorhq.com
GHL_LOCATION_ID=
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
# Get from GHL → Settings → Private Integrations
# Format: pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_PRIVATE_INTEGRATION_TOKEN=
GHL_WEBHOOK_SECRET=
# Pipeline stage substrings that trigger work order creation (comma-separated, case-insensitive)
# Defaults if unset: scheduled,confirmed,in progress,job ready,assigned
# ⚠️  Confirm exact stage names with your GHL client before going live
GHL_JOB_READY_STAGES=Diagnosis Booked,Estimate Approved,In Progress

# Database
DATABASE_URL=

# Supabase — find these at https://supabase.com/dashboard/project/_/settings/api
# NEXT_PUBLIC_ vars are safe to expose to the browser (subject to RLS).
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS — keep server-side only, never expose to browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# (Legacy var name — kept for compatibility; prefer NEXT_PUBLIC_SUPABASE_URL above)
SUPABASE_URL=

# Auth (NextAuth.js)
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Must match your dev/prod URL exactly
NEXTAUTH_URL=http://localhost:3000

# File Storage
STORAGE_BUCKET=
AVATAR_BUCKET=avatars

# App Environment
APP_ENV=development

# GHL Location ID — safe to expose to browser (used in Settings panel display only)
NEXT_PUBLIC_GHL_LOCATION_ID=

# Reporting mode — set to 'mock' when GHL token is absent or in dev
# Remove or set to 'live' once GHL integration is active
NEXT_PUBLIC_REPORTING_MODE=mock
